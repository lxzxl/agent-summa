# dependencies
node_modules/
.pnpm-store/

# build output
out/
dist/
release/
*.tsbuildinfo

# native build artifacts
build/
prebuilds/
*.node

# electron-builder packaging resources (app icon, entitlements, …) live in app/build/ —
# keep them tracked despite the `build/` rule above (that one targets node-gyp output).
!app/build/
!app/build/**

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# local index / app data (also lives in the OS userData dir, never the repo)
*.db
*.db-wal
*.db-shm

# env / secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# test / coverage
coverage/

# internal-only artifacts (kept locally, not part of the public repo):
# prior-art research notes + the UI design prototype / design-tool sidecar
docs/PRIOR-ART.md
designs/
